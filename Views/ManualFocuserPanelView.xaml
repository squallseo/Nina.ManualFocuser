<UserControl x:Class="Nina.ManualFocuser.Views.ManualFocuserPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
     
   
    <UserControl.Resources>
         
       
        <!-- NINA에 기본으로 존재하는 컨버터들:
             - BooleanToVisibilityCollapsedConverter
             - InverseBooleanConverter
        -->
         
       
        <!-- In 버튼: MoveIn <-> Stop 토글 (NINA 버튼 스타일 유지) -->
               
        <Style x:Key="MoveInStopButtonStyle" TargetType="Button" BasedOn="{StaticResource StandardButton}">
                       
            <Setter Property="Content" Value="In (-)"/>
                       
            <Setter Property="Command" Value="{Binding PanelVM.MoveInCommand}"/>
                       
            <Setter Property="IsEnabled" Value="{Binding PanelVM.MoveInEnabled}"/>
                       
            <Style.Triggers>
                               
                <DataTrigger Binding="{Binding PanelVM.IsMoveInStop}" Value="True">
                                       
                    <Setter Property="Content" Value="Stop"/>
                                       
                    <Setter Property="Command" Value="{Binding PanelVM.StopCommand}"/>
                                       
                    <Setter Property="IsEnabled" Value="True"/>
                                   
                </DataTrigger>
                           
            </Style.Triggers>
                   
        </Style>
         
       
        <!-- Out 버튼: MoveOut <-> Stop 토글 -->
               
        <Style x:Key="MoveOutStopButtonStyle" TargetType="Button" BasedOn="{StaticResource StandardButton}">
                       
            <Setter Property="Content" Value="Out (+)"/>
                       
            <Setter Property="Command" Value="{Binding PanelVM.MoveOutCommand}"/>
                       
            <Setter Property="IsEnabled" Value="{Binding PanelVM.MoveOutEnabled}"/>
                       
            <Style.Triggers>
                               
                <DataTrigger Binding="{Binding PanelVM.IsMoveOutStop}" Value="True">
                                       
                    <Setter Property="Content" Value="Stop"/>
                                       
                    <Setter Property="Command" Value="{Binding PanelVM.StopCommand}"/>
                                       
                    <Setter Property="IsEnabled" Value="True"/>
                                   
                </DataTrigger>
                           
            </Style.Triggers>
                   
        </Style>
         
       
        <!-- Go 버튼: Go <-> Stop 토글 -->
               
        <Style x:Key="GoStopButtonStyle" TargetType="Button" BasedOn="{StaticResource StandardButton}">
                       
            <Setter Property="Content" Value="Go"/>
                       
            <Setter Property="Command" Value="{Binding PanelVM.GoToCommand}"/>
                       
            <Setter Property="IsEnabled" Value="{Binding PanelVM.GoEnabled}"/>
                       
            <Style.Triggers>
                               
                <DataTrigger Binding="{Binding PanelVM.IsGoStop}" Value="True">
                                       
                    <Setter Property="Content" Value="Stop"/>
                                       
                    <Setter Property="Command" Value="{Binding PanelVM.StopCommand}"/>
                                       
                    <Setter Property="IsEnabled" Value="True"/>
                                   
                </DataTrigger>
                           
            </Style.Triggers>
                   
        </Style>
         
   
    </UserControl.Resources>
     
   
    <!-- DataContext는 Dockable, Dockable 안에 PanelVM이 있다고 가정 -->
       
    <Grid Margin="12">
               
        <Grid.RowDefinitions>
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Title -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Moving row -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Position/Temperature -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Target + Go -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Step -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Buttons -->
                       
            <RowDefinition Height="Auto"/>
                       
            <!-- Status -->
                       
            <RowDefinition Height="*"/>
                   
        </Grid.RowDefinitions>
         
       
        <!-- Title -->
               
        <TextBlock Grid.Row="0"
                   Text="Manual Focuser Input"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>
 
        <!-- Moving -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>
 
            <TextBlock Text="Moving" Opacity="0.85" VerticalAlignment="Center"/>
 
            <!-- 아이콘은 일단 단순히 X/체크 SVG로 -->
            <ContentControl Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Content">
                            <Setter.Value>
                                <Viewbox Width="18" Height="18">
                                    <Path Data="{StaticResource CancelCircledSVG}" Stretch="Uniform"/>
                                </Viewbox>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PanelVM.IsMoving}" Value="True">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Viewbox Width="18" Height="18">
                                            <Path Data="{StaticResource CheckedCircledSVG}" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
 
        <!-- Position / Temperature -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
 
            <StackPanel Grid.Column="0">
                <TextBlock Text="Position" Opacity="0.85"/>
                <TextBlock Text="{Binding PanelVM.PositionText}" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>
 
            <StackPanel Grid.Column="2" HorizontalAlignment="Left">
                <TextBlock Text="Temperature" Opacity="0.85"/>
                <TextBlock Text="{Binding PanelVM.TemperatureText}" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
 
        <!-- Target Position + Go -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
 
            <TextBox Grid.Column="0"
                     Text="{Binding PanelVM.TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource StandardTextbox}"
                     Height="32"
                     VerticalContentAlignment="Center"/>
 
            <Button Grid.Column="2"
                    Height="32"
                    Style="{StaticResource GoStopButtonStyle}"/>
        </Grid>
 
        <!-- Step -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
 
            <TextBlock Text="Step" Opacity="0.85" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding PanelVM.Step, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource StandardTextbox}"
                     Height="32"
                     VerticalContentAlignment="Center"
                     IsEnabled="{Binding PanelVM.IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
        </Grid>
 
        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
 
            <Button Grid.Column="0"
                    Height="40"
                    Style="{StaticResource MoveInStopButtonStyle}"/>
 
            <Button Grid.Column="2"
                    Height="40"
                    Style="{StaticResource MoveOutStopButtonStyle}"/>
        </Grid>
 
        <!-- Status -->
        <TextBlock Grid.Row="6"
                   Margin="0,10,0,0"
                   Text="{Binding PanelVM.Status}"
                   Opacity="0.9"
                   TextWrapping="Wrap"/>
    </Grid>
 
</UserControl>
<UserControl x:Class="Nina.ManualFocuser.Views.ManualFocuserPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Nina.ManualFocuser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DesignTimeManualFocuserPanelVM, IsDesignTimeCreatable=True}"
             d:DesignHeight="350" d:DesignWidth="520">

    <UserControl.Resources>
        <!-- Icons (vector) -->
        <PathGeometry x:Key="MF_IconX" Figures="M 5,5 L 13,13 M 13,5 L 5,13"/>
        <PathGeometry x:Key="MF_IconCheck" Figures="M 4.5,9.5 L 7.5,12.5 L 13.5,6.5"/>

        <!-- Badge base -->
        <Style x:Key="MF_Badge" TargetType="Border">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Icon stroke style -->
        <Style x:Key="MF_BadgeIcon" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
        </Style>
    </UserControl.Resources>

    <!-- Root -->
    <Grid Margin="5" Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Connected / Moving -->
            <RowDefinition Height="Auto"/>
            <!-- Position / Temp -->
            <RowDefinition Height="Auto"/>
            <!-- Target + Go -->
            <RowDefinition Height="Auto"/>
            <!-- Step + In/Out -->
            <RowDefinition Height="*"/>
            <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ===================================== -->
        <!-- Row 0: Connected (disconnected only)  -->
        <!-- ===================================== -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelVM.IsConnected}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Connected" Opacity="0.8" VerticalAlignment="Center"/>

            <Border Grid.Column="1"
                    Margin="5,0,0,0"
                    Style="{StaticResource MF_Badge}"
                    Background="{DynamicResource NotificationErrorBrush}">
                <Path Style="{StaticResource MF_BadgeIcon}"
                      Stroke="{DynamicResource NotificationErrorTextBrush}"
                      Data="{StaticResource MF_IconX}"/>
            </Border>
        </Grid>

        <!-- ===================================== -->
        <!-- Row 0: Is moving (connected only)     -->
        <!-- ===================================== -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelVM.IsConnected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Is moving" Opacity="0.8" VerticalAlignment="Center"/>

            <!-- Badge -->
            <Border Grid.Column="1" Margin="5,0,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource MF_Badge}">
                        <Setter Property="Background" Value="{DynamicResource ButtonForegroundDisabledBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PanelVM.IsMoving}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource NotificationErrorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Path>
                    <Path.Style>
                        <Style TargetType="Path" BasedOn="{StaticResource MF_BadgeIcon}">
                            <Setter Property="Stroke" Value="{DynamicResource ButtonForegroundBrush}"/>
                            <Setter Property="Data" Value="{StaticResource MF_IconX}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PanelVM.IsMoving}" Value="True">
                                    <Setter Property="Stroke" Value="{DynamicResource NotificationErrorTextBrush}"/>
                                    <Setter Property="Data" Value="{StaticResource MF_IconCheck}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
            </Border>
        </Grid>

        <!-- ===================================== -->
        <!-- Row 1: Position / Temperature          -->
        <!-- ===================================== -->
        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelVM.IsConnected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Position" Opacity="0.7"/>
                <TextBlock Text="{Binding PanelVM.PositionText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Temperature" Opacity="0.7"/>
                <TextBlock Text="{Binding PanelVM.TemperatureText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ===================================== -->
        <!-- Row 2: Target + Go/Stop                -->
        <!-- ===================================== -->
        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelVM.IsConnected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Target"
                       Opacity="0.7"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <TextBox Grid.Column="1"
                     Height="32"
                     MinWidth="90"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"
                     Text="{Binding PanelVM.TargetPosition, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Normal Go (hidden when GoTo active), disabled when any busy -->
            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PanelVM.IsGoToActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding PanelVM.IsBusy}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Button Height="32"
                        MinWidth="64"
                        Padding="12,0"
                        Content="Go"
                        Command="{Binding PanelVM.GoToCommand}"/>
            </Grid>

            <!-- Stop (visible only when GoTo active) -->
            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PanelVM.IsGoToActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Button Height="32"
                        MinWidth="64"
                        Padding="12,0"
                        Content="✕"
                        Command="{Binding PanelVM.StopCommand}"/>
            </Grid>
        </Grid>

        <!-- ===================================== -->
        <!-- Row 3: Step + In/Out (each with Stop)  -->
        <!-- ===================================== -->
        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelVM.IsConnected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Step"
                       Opacity="0.7"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <TextBox Grid.Column="1"
                     Height="32"
                     MinWidth="90"
                     VerticalContentAlignment="Center"
                     Margin="0,0,5,0"
                     Text="{Binding PanelVM.Step, UpdateSourceTrigger=PropertyChanged}"/>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ===== In normal (disabled when busy, hidden when MoveIn active) ===== -->
                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PanelVM.IsMoveInActive}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PanelVM.IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Button Height="32"
                            MinWidth="78"
                            Padding="12,0"
                            Content="In (-)"
                            Command="{Binding PanelVM.MoveInCommand}"/>
                </Grid>

                <!-- ===== In stop (visible only when MoveIn active) ===== -->
                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PanelVM.IsMoveInActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Button Height="32"
                            MinWidth="78"
                            Padding="12,0"
                            Content="✕"
                            Command="{Binding PanelVM.StopCommand}"/>
                </Grid>

                <!-- ===== Out normal (disabled when busy, hidden when MoveOut active) ===== -->
                <Grid Grid.Column="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PanelVM.IsMoveOutActive}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PanelVM.IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Button Height="32"
                            MinWidth="78"
                            Padding="12,0"
                            Content="Out (+)"
                            Command="{Binding PanelVM.MoveOutCommand}"/>
                </Grid>

                <!-- ===== Out stop (visible only when MoveOut active) ===== -->
                <Grid Grid.Column="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PanelVM.IsMoveOutActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Button Height="32"
                            MinWidth="78"
                            Padding="12,0"
                            Content="✕"
                            Command="{Binding PanelVM.StopCommand}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===================================== -->
        <!-- Row 4: Status                          -->
        <!-- ===================================== -->
        <TextBlock Grid.Row="4"
                   Margin="0,0,0,0"
                   TextWrapping="Wrap"
                   Opacity="0.85"
                   Text="{Binding PanelVM.Status}"/>
    </Grid>
</UserControl>

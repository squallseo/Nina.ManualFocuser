        <PathGeometry Figures="M 2,10 L 3,10 L 3,14 L 2,14 Z" />
        <PathGeometry Figures="M 2,13 L 6,13 L 6,14 L 2,14 Z" />

        <PathGeometry Figures="M 13,10 L 14,10 L 14,14 L 13,14 Z" />
        <PathGeometry Figures="M 10,13 L 14,13 L 14,14 L 10,14 Z" />

        <!-- 가운데 별 -->
        <PathGeometry Figures="M 8,5.0 L 9.0,7.0 L 11.2,7.0 L 9.4,8.3 L 10.1,10.4 L 8,9.2 L 5.9,10.4 L 6.6,8.3 L 4.8,7.0 L 7.0,7.0 Z" />
